<div>
  <AuDataTable
    @content={{@content}}
    @sort={{@sort}}
    @page={{@page}}
    @size={{@size}}
    @isLoading={{@isLoading}}
    @noDataMessage={{or @noDataMessage "Geen organisatie"}}
    as |t|
  >
    <t.menu as |menu|>
      <menu.general>
        <div class="au-o-box">
          <AuToggleSwitch
            @label="Verberg niet actieve organisaties"
            @checked={{@organizationStatus}}
          />
        </div>
      </menu.general>
    </t.menu>

    <t.content as |c|>
      <c.header>
        <th>Type relatie</th>
        <th>Type organisatie</th>
        <th>Organisatie</th>
        <th>Status</th>
        <th></th>
      </c.header>

      <c.body as |membership|>
        <td>
          {{#let membership.error.role.message as |errorMessage|}}
            {{! TODO: disable when an organization is selected?}}
            <MembershipRoleSelect
              @selected={{membership.role}}
              @options={{@model.roles}}
              @onChange={{(fn @updateMembershipRole membership)}}
              @error={{errorMessage}}
              @id="membership-role"
            />
            {{#if errorMessage}}
              <AuHelpText @error={{true}}>{{errorMessage}}</AuHelpText>
            {{/if}}
          {{/let}}
        </td>
        {{! TODO: get rid of conditionals and duplication here}}
        <td>
          {{#if (eq membership.member.id @model.organization.id)}}
            {{membership.organization.classification.label}}
          {{else}}
            {{membership.member.classification.label}}
          {{/if}}
        </td>
        <td>
          {{#let membership.error.role.message as |errorMessage|}}
            {{#if (eq membership.member.id @model.organization.id)}}
              {{#if @model.isWorshipAdministrativeUnit}}
                <WorshipServiceSelect
                  @disabled={{(not membership.role)}}
                  @selected={{membership.organization}}
                  @onChange={{fn (mut membership.organization)}}
                  @error={{errorMessage}}
                  id="related-worship-service"
                />
              {{else}}
                <OrganizationSelect
                  @disabled={{(not membership.role)}}
                  @selected={{membership.organization}}
                  @error={{errorMessage}}
                  @onChange={{fn (mut membership.organization)}}
                  {{! TODO: correctly limit based on organization classification and any selected membership type}}
                  @classificationCodes={{@model.organization.participantClassifications}}
                />
              {{/if}}
            {{else}}
              {{#if @model.isWorshipAdministrativeUnit}}
                <WorshipServiceSelect
                  @disabled={{(not membership.role)}}
                  @selected={{membership.member}}
                  @onChange={{fn (mut membership.member)}}
                  @error={{errorMessage}}
                  id="related-worship-service"
                />
              {{else}}
                <OrganizationSelect
                  @disabled={{(not membership.role)}}
                  @selected={{membership.member}}
                  @onChange={{fn (mut membership.member)}}
                  @error={{errorMessage}}
                  {{! TODO: correctly limit based on organization classification and any selected membership type}}
                  @classificationCodes={{@model.organization.participantClassifications}}
                />
              {{/if}}
            {{/if}}
            {{#if errorMessage}}
              <AuHelpText @error={{true}}>{{errorMessage}}</AuHelpText>
            {{/if}}
          {{/let}}
        </td>
        <td>
          {{#if (eq membership.member.id @model.organization.id)}}
            <OrganizationStatus
              @id={{membership.organization.organizationStatus.id}}
              @label={{membership.organization.organizationStatus.label}}
            />
          {{else}}
            <OrganizationStatus
              @id={{membership.member.organizationStatus.id}}
              @label={{membership.member.organizationStatus.label}}
            />
          {{/if}}
        </td>
        <td>
          <AuButton
            @alert={{true}}
            @icon="bin"
            @iconAlignment="left"
            @skin="link"
            {{on "click" (fn @removeRelatedOrganization membership)}}
          >
            Verwijder
          </AuButton>
        </td>
      </c.body>
    </t.content>
  </AuDataTable>

  <div class="au-o-box au-o-box--small">
    <AuButton
      @skin="secondary"
      @width="block"
      @icon="add"
      @iconAlignment="left"
      {{on "click" @addRelatedOrganization}}
    >
      Voeg nieuwe gerelateerde organisatie toe
    </AuButton>
  </div>
</div>