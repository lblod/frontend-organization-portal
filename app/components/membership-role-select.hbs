<div class={{if @error "ember-power-select--error"}}>
  <PowerSelect
    @loadingMessage="Aan het laden..."
    @searchField="label"
    @options={{@options}}
    @selected={{@selected}}
    @onChange={{@onChange}}
    @triggerId={{@id}}
    as |role|
  >
    {{! TODO: show extend label, in the correct reading direction}}
    {{role.label}}
  </PowerSelect>
</div>