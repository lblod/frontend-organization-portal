<AuDataTable
  @content={{@model.allMembershipRelations}}
  @sort={{@sort}}
  @page={{@page}}
  @size={{@size}}
  @isLoading={{@isLoading}}
  @noDataMessage={{or @noDataMessage "Geen organisatie"}}
  as |t|
>

  <t.menu as |menu|>
    <menu.general>
      <div class="au-o-box">
        <AuToggleSwitch
          @label="Verberg niet actieve organisaties"
          @checked={{@organizationStatus}}
        />
      </div>
    </menu.general>
  </t.menu>

  <t.content as |c|>
    <c.header>
      {{! TODO: use [inverse]OpLabel }}
      <AuDataTableThSortable
        @field="role.label"
        @label="Type relatie"
        @currentSorting={{@sort}}
      />
      {{! TODO: consider `member` relation as well when sorting }}
      <AuDataTableThSortable
        @field="organization.classification.label"
        @label="Type organisatie"
        @currentSorting={{@sort}}
      />
      <AuDataTableThSortable
        @field="organization.name"
        @label="Organisatie"
        @currentSorting={{@sort}}
      />
      <AuDataTableThSortable
        @field="organization.organizationStatus.label"
        @label="Status"
        @currentSorting={{@sort}}
      />
    </c.header>

    {{! TODO: move conditional logic to controller?  }}
    <c.body as |membership|>
      <td>
        {{#if (eq membership.organization.id @model.organization.id)}}
          {{membership.role.inverseOpLabel}}
        {{else}}
          {{membership.role.opLabel}}
        {{/if}}
      </td>
      <td>
        {{#if (eq membership.organization.id @model.organization.id)}}
          {{membership.member.classification.label}}
        {{else}}
          {{membership.organization.classification.label}}
        {{/if}}
      </td>
      <td>
        {{#if (eq membership.organization.id @model.organization.id)}}
          <AuLink
            @route="organizations.organization"
            @model={{membership.member.id}}
          >
            {{membership.member.abbName}}
          </AuLink>
        {{else}}
          <AuLink
            @route="organizations.organization"
            @model={{membership.organization.id}}
          >
            {{membership.organization.abbName}}
          </AuLink>
        {{/if}}
      </td>
      <td>
        {{#if (eq membership.organization.id @model.organization.id)}}
          <OrganizationStatus
            @id={{membership.member.organizationStatus.id}}
            @label={{membership.member.organizationStatus.label}}
          />
        {{else}}
          <OrganizationStatus
            @id={{membership.organization.organizationStatus.id}}
            @label={{membership.organization.organizationStatus.label}}
          />
        {{/if}}
      </td>
    </c.body>
  </t.content>
</AuDataTable>